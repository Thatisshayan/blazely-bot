# 
# Blazely Telegram Bot Configuration  v2
# 

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram chat ID (find via @userinfobot)
ADMIN_CHAT_IDS=123456789

# Commission settings
COMMISSION_RATE=0.15
DEAL_PRICE=399

# Database
DB_PATH=blazely_crm.db

#  n8n Webhook URLs 
# Set these AFTER importing workflows into n8n.
# Leave blank to run bot without n8n (standalone mode).
N8N_LEAD_WEBHOOK=
N8N_STATUS_WEBHOOK=
N8N_REP_WEBHOOK=
